library(tidyverse)
library(gtsummary)
library(medicaldata)
attach(smartpill)
data(smartpill)
head(smartpill)
names(smartpill)
ggplot(data = smartpill, aes(x = SB.Time, y = GE.Time), color = Group)) +
ggplot(data = smartpill, aes(x = SB.Time, y = GE.Time, color = Group)) +
geom_point()
ggplot(data = smartpill, aes(x = SB.Time, y = GE.Time, color = as.factor(Group))) +
geom_point()
ggplot(data = smartpill, aes(x = SB.Time, y = GE.Time, color = as.factor(Gender)) +
geom_point()
ggplot(data = smartpill, aes(x = SB.Time, y = GE.Time, color = as.factor(Gender))) +
geom_point()
ggplot(data = smartpill, aes(x = SB.Time, y = GE.Time, color = Weight) +
geom_point()
ggplot(data = smartpill, aes(x = SB.Time, y = GE.Time, color = Weight)) +
geom_point()
